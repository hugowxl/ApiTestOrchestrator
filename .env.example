# 应用
APP_NAME=api-test-orchestrator
DEBUG=false
# 浏览器直连 API 时的 CORS（逗号分隔）；留空则不启用 CORS 中间件
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 文件日志目录：{LOG_APPLOG_BASE}/{LOG_PROJECT_NAME 或 APP_NAME}/root.log
LOG_APPLOG_BASE=D:/applog
# LOG_PROJECT_NAME=

# 数据库（PostgreSQL 或 SQLite）
DATABASE_URL=sqlite:///./data/app.db

# 默认执行测试时的目标 Base URL（可被请求体覆盖）
DEFAULT_TARGET_BASE_URL=http://localhost:8080

# LLM（OpenAI 兼容接口）
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# HTTPS：公司 SSL 解密/自签链导致 CERTIFICATE_VERIFY_FAILED 时，优先导出根证书 PEM 并设置：
# LLM_CA_BUNDLE=D:/certs/corp-root.pem
# 仅内网排障可关闭校验（不安全）：
# LLM_VERIFY_SSL=false
LLM_VERIFY_SSL=true
# 单次 LLM 请求超时（秒）；模型慢或 prompt 很大时可加大，与下方执行 HTTP 的超时无关
LLM_TIMEOUT_SECONDS=120.0

# HTTP 客户端（执行用例时的下游 API）
HTTP_TIMEOUT_SECONDS=30.0
# 被测服务为 HTTPS 且证书为公司自签/解密代理时：可设 PEM 路径，或仅排障时关闭校验（不安全）
# EXECUTOR_CA_BUNDLE=D:/certs/corp-root.pem
EXECUTOR_VERIFY_SSL=true
